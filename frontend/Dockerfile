# =========================================
# Stage 1: Build the Next.js Application
# =========================================
ARG NODE_VERSION=22.16.0-alpine

FROM node:${NODE_VERSION} AS builder
WORKDIR /app

# Copy dependency files and install
COPY package.json package-lock.json* ./
RUN --mount=type=cache,target=/root/.npm npm ci

# Copy source code and build
COPY . .
RUN npm run build

# =========================================
# Stage 2: The Node.js Production Server
# =========================================
FROM node:${NODE_VERSION} AS runner
WORKDIR /app

# Set environment to production for better performance
ENV NODE_ENV=production

# Create a non-root user for security (similar to what we did with Nginx)
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs
USER nextjs

# Copy the necessary public files (images, fonts, etc.)
COPY --from=builder /app/public ./public

# Copy the standalone server generated by Next.js
COPY --chown=nextjs:nodejs --from=builder /app/.next/standalone ./

# Copy the static assets generated by Next.js
COPY --chown=nextjs:nodejs --from=builder /app/.next/static ./.next/static

# Expose Next.js default port
EXPOSE 3000

# Start the standalone Node server
CMD ["node", "server.js"]