# Postgres (containerized via docker-compose service name "postgres")
DATABASE_URL="postgresql://gw:gw_pw@postgres:5432/guardianway"
# No connection pooler in self-hosted setup, so DIRECT_URL == DATABASE_URL
DIRECT_URL="postgresql://gw:gw_pw@postgres:5432/guardianway"

# Redis (containerized via docker-compose service name "redis"), non-TLS
REDIS_URL="redis://redis:6379"

# Auth — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET="replace-me"
JWT_REFRESH_SECRET="replace-me"

# Frontend origin allowed by CORS
WEB_BASE_URL="http://localhost:3000"
